{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "schematicCollections": ["angular-eslint"]
  },
  "newProjectRoot": "projects",
  "projects": {
    "admin": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/admin",
      "sourceRoot": "projects/admin/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/admin/src/main.ts",
            "tsConfig": "projects/admin/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/admin/public"
              }
            ],
            "styles": ["projects/admin/src/styles.scss"],
            "server": "projects/admin/src/main.server.ts",
            "outputMode": "server",
            "ssr": {
              "entry": "projects/admin/src/server.ts"
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "admin:build:production"
            },
            "development": {
              "buildTarget": "admin:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "coverage": true,
            "coverageReporters": ["text", "cobertura", "html"]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["projects/admin/**/*.ts", "projects/admin/**/*.html"],
            "eslintConfig": "projects/admin/eslint.config.js"
          }
        }
      }
    },
    "@editor/data": {
      "projectType": "library",
      "root": "projects/editor/data",
      "sourceRoot": "projects/editor/data/src",
      "prefix": "editor",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/editor/data/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/editor/data/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "configurations": {},
          "options": {
            "tsConfig": "projects/editor/data/tsconfig.spec.json",
            "coverageExclude": ["src/lib/generated"],
            "coverageReporters": ["html", "lcov"],
            "coverageWatermarks": {
              "statements": [80, 80],
              "branches": [80, 80],
              "functions": [80, 80],
              "lines": [80, 80]
            }
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["projects/editor/data/**/*.ts", "projects/editor/data/**/*.html"],
            "eslintConfig": "projects/editor/data/eslint.config.js"
          }
        }
      }
    },
    "@editor/feature-overview": {
      "projectType": "library",
      "root": "projects/editor/feature-overview",
      "sourceRoot": "projects/editor/feature-overview/src",
      "prefix": "editor",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/editor/feature-overview/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/editor/feature-overview/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/editor/feature-overview/tsconfig.spec.json"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/editor/feature-overview/**/*.ts",
              "projects/editor/feature-overview/**/*.html"
            ],
            "eslintConfig": "projects/editor/feature-overview/eslint.config.js"
          }
        }
      }
    },
    "@editor/ui-page-list": {
      "projectType": "library",
      "root": "projects/editor/ui-page-list",
      "sourceRoot": "projects/editor/ui-page-list/src",
      "prefix": "editor",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/editor/ui-page-list/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/editor/ui-page-list/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/editor/ui-page-list/tsconfig.spec.json"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/editor/ui-page-list/**/*.ts",
              "projects/editor/ui-page-list/**/*.html"
            ],
            "eslintConfig": "projects/editor/ui-page-list/eslint.config.js"
          }
        }
      }
    }
  }
}
